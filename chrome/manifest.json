{
  "manifest_version": 3,
  "name": "Volume Booster",
  "version": "1.0.0",
  "description": "Boost the volume of any audio or video in your browser up to 600%. No data collection, completely private.",
  "author": "Rama Jha",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage"]
}
